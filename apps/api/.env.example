# Local development defaults are baked into docker-compose.dev.yml.
# Use this file as a reference for what variables exist and what they mean.
# For PRODUCTION, these are stored as GitHub Encrypted Secrets and pushed
# to the EC2 by the deploy workflow via SSM Run-Command. They never appear
# in source, in the image, or in CI logs (GH masks them automatically).
# See docs/TRADEOFFS.md for why GH Secrets over SSM Parameter Store.

# --- Database ----------------------------------------------------------
# This DATABASE_URL is for HOST-SIDE use only (pytest from your laptop,
# psql, alembic outside docker). The dockerised api container builds its
# own DATABASE_URL pointing at the `db` service on the Docker network —
# overriding this var has NO effect on the running container.
#
# If you changed POSTGRES_HOST_PORT, match it here.
DATABASE_URL=postgresql+psycopg://salary:salary@localhost:5432/salary_manager

# --- Auth --------------------------------------------------------------
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_MINUTES=1440

# --- CORS --------------------------------------------------------------
# Comma-separated list. In prod, set to the Vercel frontend origin.
CORS_ORIGINS=http://localhost:3000

# --- Anthropic ---------------------------------------------------------
# Only the backend ever sees this. Never expose to the frontend bundle.
ANTHROPIC_API_KEY=sk-ant-...

# --- Seed (only read by the seed script) -------------------------------
HR_USER_EMAIL=hr@acme.org
HR_USER_PASSWORD=acme-demo-2026

# --- Local host ports (only used by docker-compose.dev.yml) -------------
# Override if 5432 / 8000 are already taken on your machine.
POSTGRES_HOST_PORT=5432
API_HOST_PORT=8000
